# ============================================================
# 幕布AI分析工具 - 配置文件
# 使用方法：复制本文件为 .env，然后填入你的配置
# ============================================================

# ---- AI 模型配置 ----
# 选择你要使用的 AI 服务，填入对应的 API Key 和 Base URL

# 【方案1】OpenAI (ChatGPT)
# API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# BASE_URL=https://api.openai.com/v1
# MODEL_NAME=gpt-4o

# 【方案2】DeepSeek（国内访问稳定，性价比高）
# API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# BASE_URL=https://api.deepseek.com/v1
# MODEL_NAME=deepseek-chat

# 【方案3】Kimi (月之暗面)
# API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# BASE_URL=https://api.moonshot.cn/v1
# MODEL_NAME=moonshot-v1-128k

# 【方案4】通义千问 (阿里云)
# API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# MODEL_NAME=qwen-long

# 【方案5】智谱AI (GLM)
# API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx.xxxxxxxxxx
# BASE_URL=https://open.bigmodel.cn/api/paas/v4
# MODEL_NAME=glm-4-long

# 【当前激活的配置 - 取消注释并填写】
API_KEY=你的API_Key填在这里
BASE_URL=https://api.deepseek.com/v1
MODEL_NAME=deepseek-chat

# ---- 处理参数配置 ----
# 每个文本块的最大字符数（建议2000-4000，越大越贵但上下文越完整）
CHUNK_SIZE=3000

# 相邻文本块之间的重叠字符数（防止内容在分块边界被截断）
CHUNK_OVERLAP=200

# 并发请求数（同时向AI发送几个请求，建议3-5，太高会触发限流）
CONCURRENCY=3

# 每次API请求之间的间隔秒数（防止触发限流）
REQUEST_DELAY=0.5

# API 请求超时时间（秒）
TIMEOUT=120

# ---- 路径配置 ----
# PDF 文件所在目录（支持子目录，会自动递归扫描）
PDF_INPUT_DIR=./input_pdfs

# 分析结果输出目录
OUTPUT_DIR=./output

# ---- 任务模式配置 ----
# 任务模式：
#   single_summary  = 对每篇文档单独生成摘要（推荐，速度快）
#   global_analysis = 在单篇摘要基础上，再做全局分析（更深入，消耗更多Token）
TASK_MODE=single_summary

# 是否开启断点续传（True=跳过已处理的文件，False=全部重新处理）
RESUME=True
